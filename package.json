{
  "name": "@lpirito/pi-diffloop",
  "version": "0.0.1",
  "description": "Human-in-the-loop review for Pi edit/write tool calls",
  "scripts": {
    "typecheck": "bunx tsc -p tsconfig.json",
    "test": "bun test",
    "check": "bun run typecheck && bun run test",
    "release:dry": "bun run check && bun publish --dry-run",
    "release": "bun run check && bun publish --access public"
  },
  "files": [
    "index.ts",
    "diff-preview.ts",
    "utils.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "diff-review",
    "agent-extension",
    "review",
    "code-review"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.65.0",
    "@mariozechner/pi-tui": "0.65.0",
    "@sinclair/typebox": "0.34.49",
    "diff": "8.0.4"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}