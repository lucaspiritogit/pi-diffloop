{
  "name": "@lpirito/pi-diffloop",
  "version": "0.0.6",
  "main": "dist/index.js",
  "description": "Human-in-the-loop review for Pi edit/write tool calls",
  "scripts": {
    "build": "rm -rf dist && bunx tsc -p tsconfig.json",
    "prepack": "bun run build",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "check": "bun run build && bun run typecheck && bun run test",
    "release:dry": "bun run check && bun publish --dry-run",
    "release": "npm version patch && bun run check && bun publish --access public",
    "release:patch": "npm version patch && npm publish --access public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi-extension",
    "diff-review",
    "agent-extension",
    "review",
    "code-review"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "diff": "8.0.4"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucaspiritogit/pi-diffloop"
  }
}
