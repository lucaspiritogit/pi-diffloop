{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "esnext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "outDir": "./dist"
  }
}
