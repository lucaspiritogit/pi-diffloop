{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "CommonJS",
    "target": "ESNext",
    "moduleResolution": "node",
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["bun"],
    "outDir": "./dist"
  },
  "include": ["index.ts", "diff-preview.ts", "utils.ts"],
  "exclude": ["dist", "node_modules", "*.test.ts"]
}
